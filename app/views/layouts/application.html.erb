<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rosary" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Japamala">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#111111">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application" %>
    <%= javascript_include_tag "application" %>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: 'Lora', Georgia, serif;
        background: #f0f0ed;
        color: #111;
        -webkit-text-size-adjust: 100%;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        min-height: 100vh; min-height: 100dvh;
      }

      /* App shell — locked to true viewport height, no page scroll */
      .app {
        height: 100vh; height: 100dvh;
        width: 100%;
        max-width: 560px;
        display: flex; flex-direction: column;
        overflow: hidden;
        position: relative;
        background: #fff;
        box-shadow: 0 0 60px rgba(0,0,0,0.08);
        --accent: #e8a020;
        --accent-dark: #c88a10;
        --accent-glow: rgba(232,160,32,0.2);
        --accent-bg: #fffbf0;
      }

      /* Color schemes */
      .app.color-rose   { --accent: #e05078; --accent-dark: #bf3a5e; --accent-glow: rgba(224,80,120,0.2); --accent-bg: #fff0f4; }
      .app.color-blue   { --accent: #3b82f6; --accent-dark: #2563eb; --accent-glow: rgba(59,130,246,0.2);  --accent-bg: #eff6ff; }
      .app.color-teal   { --accent: #0ea5a0; --accent-dark: #0c8a85; --accent-glow: rgba(14,165,160,0.2);  --accent-bg: #f0fdfb; }
      .app.color-purple { --accent: #8b5cf6; --accent-dark: #7c3aed; --accent-glow: rgba(139,92,246,0.2);  --accent-bg: #f5f3ff; }

      /* Header */
      .app-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.9rem 1.5rem;
        border-bottom: 1px solid #eee;
        flex-shrink: 0;
      }
      .mystery-day  { font-size: 0.7rem; color: var(--accent); opacity: 0.8; font-family: monospace; text-transform: uppercase; letter-spacing: 0.1em; }
      .mystery-name { font-size: 0.95rem; font-weight: 600; color: #222; margin-top: 0.15rem; display: flex; align-items: center; }
      .step-counter { font-family: monospace; font-size: 0.68rem; color: var(--accent); opacity: 0.65; margin-top: 0.2rem; display: block; }
      .header-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.35rem; }
      .header-btns { display: flex; align-items: center; gap: 0.4rem; }
      .lang-btn {
        background: none; border: 1px solid var(--accent); border-radius: 20px;
        padding: 0.2rem 0.65rem; font-size: 0.65rem; cursor: pointer;
        color: var(--accent); opacity: 0.75; font-family: monospace; transition: all 0.15s;
        white-space: nowrap;
      }
      .lang-btn:hover { opacity: 1; background: var(--accent-bg); }

      /* Color swatches */
      .color-swatches { display: flex; align-items: center; gap: 6px; margin-top: 0.4rem; }
      .color-dot { width: 12px; height: 12px; border-radius: 50%; cursor: pointer; transition: transform 0.15s; flex-shrink: 0; }
      .color-dot:hover { transform: scale(1.2); }
      .color-dot-active { box-shadow: 0 0 0 2px #fff, 0 0 0 3px currentColor; transform: scale(1.15); }

      /* Progress */
      .progress-wrap { height: 2px; background: #f5f5f5; flex-shrink: 0; }
      .progress-fill { height: 2px; background: var(--accent); transition: width 0.4s ease; }

      /* Content — scrolls internally, nav stays visible */
      .content {
        flex: 1; display: flex; flex-direction: column;
        max-width: 560px; width: 100%;
        margin: 0 auto; padding: 1.75rem 1.5rem 2rem;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
      }

      /* Decade dots */
      .decade-dots { display: flex; gap: 8px; margin-bottom: 0.75rem; }
      .decade-dot {
        width: 26px; height: 26px; border-radius: 50%;
        border: 1.5px solid #e0e0e0; background: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 10px; font-weight: 700; color: #ccc;
        font-family: monospace; transition: all 0.2s;
      }
      .decade-dot.done { background: var(--accent); border-color: var(--accent); color: #fff; }
      .decade-dot.active { border-color: var(--accent); color: var(--accent); background: var(--accent-bg); }

      /* Bead track */
      .bead-track-wrapper { position: relative; margin-bottom: 1.75rem; }
      .bead-track-line {
        position: absolute; left: 0; right: 0; top: 50%;
        height: 1.5px; background: #efefef; z-index: 0;
        transform: translateY(-50%);
      }
      .bead-track { position: relative; z-index: 1; display: flex; align-items: center; gap: 4px; }
      .bead {
        width: 18px; height: 18px; border-radius: 50%;
        border: 1.5px solid #e0e0e0; background: #fff;
        flex-shrink: 0; transition: all 0.2s;
      }
      .bead.bead-special { border-radius: 4px; width: 22px; height: 22px; }
      .bead.bead-done { background: var(--accent-dark); border-color: var(--accent-dark); }
      .bead.bead-active { background: var(--accent); border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }

      /* Prayer screen */
      .prayer-context { font-size: 0.78rem; color: var(--accent); opacity: 0.7; font-style: italic; margin-bottom: 1.25rem; }
      .prayer-heading {
        font-size: 3rem; font-weight: 700; line-height: 1.1;
        letter-spacing: -0.02em; color: #111; margin: 0 0 0.4rem;
        overflow-wrap: break-word;
      }
      .prayer-count { font-family: monospace; font-size: 0.9rem; color: var(--accent); margin-bottom: 1.5rem; }
      .prayer-body {
        border-top: 1px solid #eee; padding-top: 1.25rem;
        font-size: 1.05rem; line-height: 1.85; color: #333;
        flex: 1;
      }

      /* Word highlight during TTS */
      .prayer-word { border-radius: 3px; transition: background 0.1s, color 0.1s; }
      .prayer-word.word-active { background: var(--accent-bg); color: var(--accent); }

      /* Mystery announce */
      .mystery-ordinal {
        font-family: monospace; font-size: 0.72rem; color: #bbb;
        text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 0.4rem;
      }
      .mystery-heading {
        font-size: 2.6rem; font-weight: 700; line-height: 1.15;
        color: #111; margin: 0 0 1.25rem;
        overflow-wrap: break-word;
      }
      .mystery-desc { font-size: 1rem; line-height: 1.85; color: #666; flex: 1; }

      /* Closing */
      .closing-label {
        font-family: monospace; font-size: 0.72rem; color: #bbb;
        text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 1.5rem;
      }

      /* Nav — shared (inline on short viewports) */
      .nav-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1rem 1.5rem;
        border-top: 1px solid #f0f0f0;
        flex-shrink: 0;
        background: #fff;
      }

      /* Nav — floating on tall viewports */
      @media (min-height: 700px) {
        .app { --nav-h: 5rem; }
        .content { padding-bottom: var(--nav-h); }
        /* Both themes float by default */
        .nav-row {
          position: absolute;
          bottom: 1.5rem;
          left: 50%;
          transform: translateX(-50%);
          width: calc(100% - 3rem);
          max-width: 520px;
          border-top: 1px solid #f0f0f0;
          padding: 0.9rem 2rem;
          background: #fff;
        }
        /* Classic: glass pill */
        .app.classic .nav-row {
          border-radius: 16px;
          background: rgba(255,255,255,0.88);
          backdrop-filter: blur(14px);
          -webkit-backdrop-filter: blur(14px);
          box-shadow: 0 4px 24px rgba(0,0,0,0.1), 0 1px 6px rgba(0,0,0,0.06);
        }
      }
      /* Minimal on mobile: full-width flush footer */
      @media (min-height: 700px) and (max-width: 639px) {
        .app:not(.classic) .nav-row {
          bottom: 0;
          left: 0;
          right: 0;
          transform: none;
          width: 100%;
          max-width: 100%;
          padding: 0.9rem 2rem 1.5rem;
        }
      }
      .btn-nav { background: none; border: none; padding: 0; cursor: pointer; line-height: 1; }
      .btn-nav:disabled { opacity: 0.15; cursor: default; pointer-events: none; }

      /* Nav — minimal: plain arrow icons */
      .app:not(.classic) .btn-nav {
        font-size: 1.5rem; color: var(--accent);
        transition: color 0.15s;
      }
      .app:not(.classic) .btn-nav:hover:not(:disabled) { color: var(--accent-dark); }

      /* Nav — classic: icon buttons */
      .app.classic .btn-nav { transition: transform 0.15s; }
      .app.classic .btn-nav:hover:not(:disabled) { transform: scale(1.1); }
      .app.classic .btn-nav:active:not(:disabled) { transform: scale(0.9); }

      /* Auto-play toggle button */
      .btn-nav-auto {
        background: none; border: none; padding: 0.2rem 0.4rem; cursor: pointer;
        font-size: 1rem; color: #ccc; border-radius: 6px;
        transition: color 0.15s, background 0.15s;
      }
      .btn-nav-auto:disabled { opacity: 0.15; cursor: default; pointer-events: none; }
      .btn-nav-auto:hover:not(:disabled) { color: var(--accent); }
      .btn-nav-auto.btn-nav-auto-on { color: var(--accent); background: var(--accent-bg); }

      /* Completion */
      .completion {
        flex: 1; display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center; padding: 2rem 1.5rem;
        min-width: 528px;
      }
      @media (max-width: 560px) {
        .completion { min-width: calc(100vw - 3rem); }
      }
      .completion-icon { font-size: 3.5rem; color: var(--accent); margin-bottom: 1.5rem; line-height: 1; }
      .completion-symbol { font-size: 3rem; color: var(--accent); margin: 0 0 1.5rem; line-height: 1; }
      .completion-heading { font-size: 2rem; font-weight: 700; color: #111; margin: 0 0 0.5rem; }
      .completion-sub { font-size: 1rem; color: #888; margin-bottom: 2.5rem; }
      .btn-restart {
        background: var(--accent); color: #fff; border: none;
        border-radius: 30px; padding: 0.75rem 2.5rem;
        font-family: 'Lora', serif; font-size: 1rem; cursor: pointer;
        transition: background 0.15s;
        display: inline-flex; align-items: center; gap: 0.5rem;
      }
      .btn-restart:hover { background: var(--accent-dark); }

      /* Minimal completion overrides */
      .app:not(.classic) .completion-heading { font-size: 2.8rem; letter-spacing: -0.02em; }
      .app:not(.classic) .btn-restart {
        background: none; border: none; border-bottom: 1px solid var(--accent);
        border-radius: 0; padding: 0.2rem 0; color: var(--accent);
        font-family: 'Lora', serif; font-size: 0.95rem; cursor: pointer;
        transition: color 0.15s, border-color 0.15s; opacity: 0.8;
      }
      .app:not(.classic) .btn-restart:hover { opacity: 1; }

      /* ── Announcement screen ── */
      /* Minimal: accent rule above ordinal + accent heading */
      .app:not(.classic) .mystery-ordinal {
        color: var(--accent); font-size: 0.78rem; letter-spacing: 0.2em;
        border-top: 2px solid var(--accent); padding-top: 1rem; margin-top: 0.25rem;
      }
      .app:not(.classic) .mystery-heading { color: var(--accent-dark); }

      /* Classic: accent background wash + ordinal badge + desc card */
      .app.classic .content-announce { background: #fffdf7; }
      .app.classic .mystery-ordinal {
        display: inline-block;
        background: var(--accent-bg); border: 1px solid var(--accent); border-radius: 20px;
        padding: 0.2rem 0.85rem; font-size: 0.7rem; color: var(--accent-dark);
        font-family: monospace; letter-spacing: 0.1em; text-transform: uppercase;
        margin-bottom: 0.75rem;
      }
      .app.classic .mystery-desc {
        flex: initial;
        background: #fff; border-radius: 8px;
        padding: 1.25rem 1.25rem 1.25rem 1.5rem;
        border-left: 4px solid var(--accent);
        box-shadow: 0 1px 5px rgba(0,0,0,0.08);
        color: #444; margin-bottom: 0.5rem;
      }

      /* ── Classic theme overrides ── */
      .app.classic { background: #f8f9fa; }

      .app.classic .app-header {
        box-shadow: 0 1px 4px rgba(0,0,0,0.07);
      }
      .app.classic .mystery-name { font-size: 1rem; }

      .app.classic .prayer-heading { font-size: 2.2rem; letter-spacing: normal; }
      .app.classic .mystery-heading { font-size: 2rem; letter-spacing: normal; }

      .app.classic .prayer-count {
        display: inline-block;
        background: var(--accent-bg); border: 1px solid var(--accent); border-radius: 20px;
        padding: 0.15rem 0.8rem; font-size: 0.78rem; color: var(--accent-dark);
        margin-bottom: 1.5rem;
      }
      .app.classic .prayer-body {
        border-top: none; padding-top: 0; flex: initial;
        background: #fff; border-radius: 8px;
        padding: 1.25rem 1.25rem 1.25rem 1.5rem;
        border-left: 4px solid var(--accent);
        box-shadow: 0 1px 5px rgba(0,0,0,0.08);
        margin-bottom: 0.5rem;
      }
      .app.classic .decade-dot { width: 30px; height: 30px; }
      .app.classic .bead { width: 20px; height: 20px; }
      .app.classic .bead.bead-special { width: 25px; height: 25px; }

      /* ── Mystery picker menu ── */
      .mystery-selector { cursor: pointer; }
      .mystery-selector:hover .mystery-name { opacity: 0.75; }
      .mystery-type-icon { font-size: 0.75rem; color: var(--accent); margin-right: 0.4rem; flex-shrink: 0; }
      .mystery-selector-icon {
        font-size: 0.75rem; color: var(--accent); margin-left: 0.35rem; flex-shrink: 0; vertical-align: middle;
      }

      .menu-overlay {
        position: absolute; inset: 0;
        background: rgba(0,0,0,0.35);
        z-index: 100;
      }
      .mystery-menu {
        position: absolute; bottom: 0; left: 0; right: 0;
        background: #fff; border-radius: 16px 16px 0 0;
        padding: 1.25rem 1.5rem 2.5rem;
        z-index: 101;
        max-width: 560px; margin: 0 auto;
      }
      .menu-title {
        font-family: monospace; font-size: 0.65rem; color: #bbb;
        text-transform: uppercase; letter-spacing: 0.12em;
        margin-bottom: 0.75rem;
      }
      .menu-item {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.85rem 0; border-bottom: 1px solid #f5f5f5;
        cursor: pointer; transition: opacity 0.1s;
      }
      .menu-item:last-of-type { border-bottom: none; }
      .menu-item:active { opacity: 0.5; }
      .menu-item-name { font-size: 1rem; font-weight: 600; color: #222; }
      .menu-item-days {
        font-family: monospace; font-size: 0.68rem; color: #bbb; margin-top: 0.1rem;
      }
      .menu-item-today .menu-item-name { color: var(--accent); }
      .menu-item-today .menu-item-days { color: var(--accent); opacity: 0.75; }
      .menu-item-icon { font-size: 1rem; color: var(--accent); flex-shrink: 0; margin-right: 0.85rem; }
      .menu-item-text { flex: 1; min-width: 0; }
      .menu-check { color: var(--accent); font-size: 1.1rem; flex-shrink: 0; }

      .menu-item-confirm .menu-item-name { color: var(--accent-dark); }
      .menu-item-confirm .menu-item-days { color: var(--accent-dark); opacity: 0.75; }
      .menu-item-confirm { background: var(--accent-bg); margin: 0 -1.5rem; padding-left: 1.5rem; padding-right: 1.5rem; }

      .menu-warning {
        border-top: 1px solid #f5f5f5; margin-top: 0.5rem; padding-top: 1rem;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
      }
      .menu-warning-text {
        font-size: 0.78rem; color: #999; font-style: italic; flex: 1;
      }
      .menu-warning-actions { display: flex; gap: 0.5rem; flex-shrink: 0; }
      .menu-btn {
        border: none; border-radius: 20px; padding: 0.35rem 1rem;
        font-family: 'Lora', serif; font-size: 0.78rem; cursor: pointer; transition: opacity 0.15s;
      }
      .menu-btn-cancel { background: #f0f0f0; color: #666; }
      .menu-btn-cancel:hover { opacity: 0.75; }
      .menu-btn-switch { background: var(--accent); color: #fff; }
      .menu-btn-switch:hover { background: var(--accent-dark); }

      @media (min-width: 640px) {
        .mystery-menu {
          bottom: auto; top: 50%; left: 50%; right: auto;
          transform: translate(-50%, -50%);
          width: 400px; border-radius: 16px;
          padding: 1.5rem 1.75rem 1.75rem;
          box-shadow: 0 8px 40px rgba(0,0,0,0.18);
        }
      }

      @media (max-width: 600px) {
        .prayer-heading  { font-size: 2.3rem; }
        .mystery-heading { font-size: 2rem; }
        .content { padding-top: 1.25rem; padding-left: 1.25rem; padding-right: 1.25rem; }
        .app.classic .prayer-heading  { font-size: 1.9rem; }
        .app.classic .mystery-heading { font-size: 1.7rem; }
      }

      /* Fixed bead header */
      .bead-header {
        flex-shrink: 0;
        padding: 0.75rem 1.5rem 0.6rem;
        border-bottom: 1px solid #f0f0f0;
        background: #fff;
      }
      .app.classic .bead-header { background: #f8f9fa; }
      .bead-header .bead-track-wrapper { margin-bottom: 0; }
      .bead-header .decade-dots { margin-bottom: 0.5rem; }
      .decade-dot { cursor: pointer; }
      .decade-dot.active { cursor: default; }
      .bead-track .bead { cursor: pointer; }
      .bead-track .bead.bead-active { cursor: default; }

      /* Jump confirm modal */
      .jump-confirm {
        position: absolute; bottom: 0; left: 0; right: 0;
        background: #fff; border-radius: 16px 16px 0 0;
        padding: 1.5rem 1.5rem 2.5rem;
        z-index: 101;
        max-width: 560px; margin: 0 auto;
      }
      .jump-confirm-title { font-size: 1.05rem; font-weight: 600; color: #222; margin: 0 0 0.35rem; }
      .jump-confirm-body  { font-size: 0.85rem; color: #999; margin: 0 0 1.25rem; }
      @media (min-width: 640px) {
        .jump-confirm {
          bottom: auto; top: 50%; left: 50%; right: auto;
          transform: translate(-50%, -50%);
          width: 360px; border-radius: 16px;
          padding: 1.5rem 1.75rem 1.75rem;
          box-shadow: 0 8px 40px rgba(0,0,0,0.18);
        }
      }

      @media (max-width: 600px) {
        .bead-header { padding-left: 1.25rem; padding-right: 1.25rem; }
      }
    </style>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
