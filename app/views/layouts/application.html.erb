<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rosary" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application" %>
    <%= javascript_include_tag "application" %>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: 'Lora', Georgia, serif;
        background: #fff;
        color: #111;
        -webkit-text-size-adjust: 100%;
      }

      /* App shell */
      .app { min-height: 100vh; display: flex; flex-direction: column; }

      /* Header */
      .app-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.9rem 1.5rem;
        border-bottom: 1px solid #eee;
      }
      .mystery-day  { font-size: 0.7rem; color: #bbb; font-family: monospace; text-transform: uppercase; letter-spacing: 0.1em; }
      .mystery-name { font-size: 0.95rem; font-weight: 600; color: #222; margin-top: 0.15rem; }
      .header-right { display: flex; align-items: center; gap: 1rem; }
      .step-counter { font-family: monospace; font-size: 0.78rem; color: #ccc; }
      .lang-btn {
        background: none; border: 1px solid #ddd; border-radius: 20px;
        padding: 0.2rem 0.75rem; font-size: 0.7rem; cursor: pointer;
        color: #888; font-family: monospace; transition: all 0.15s;
      }
      .lang-btn:hover { border-color: #bbb; color: #444; }

      /* Progress */
      .progress-wrap { height: 2px; background: #f5f5f5; }
      .progress-fill { height: 2px; background: #e8a020; transition: width 0.4s ease; }

      /* Content */
      .content {
        flex: 1; display: flex; flex-direction: column;
        max-width: 560px; width: 100%;
        margin: 0 auto; padding: 1.75rem 1.5rem 2rem;
      }

      /* Decade dots */
      .decade-dots { display: flex; gap: 8px; margin-bottom: 0.75rem; }
      .decade-dot {
        width: 26px; height: 26px; border-radius: 50%;
        border: 1.5px solid #e0e0e0; background: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 10px; font-weight: 700; color: #ccc;
        font-family: monospace; transition: all 0.2s;
      }
      .decade-dot.done { background: #e8a020; border-color: #e8a020; color: #fff; }
      .decade-dot.active { border-color: #e8a020; color: #e8a020; background: #fffbf0; }

      /* Bead track */
      .bead-track-wrapper { position: relative; margin-bottom: 1.75rem; }
      .bead-track-line {
        position: absolute; left: 0; right: 0; top: 50%;
        height: 1.5px; background: #efefef; z-index: 0;
        transform: translateY(-50%);
      }
      .bead-track { position: relative; z-index: 1; display: flex; align-items: center; gap: 4px; }
      .bead {
        width: 18px; height: 18px; border-radius: 50%;
        border: 1.5px solid #e0e0e0; background: #fff;
        flex-shrink: 0; transition: all 0.2s;
      }
      .bead.bead-special { border-radius: 4px; width: 22px; height: 22px; }
      .bead.bead-done { background: #c88a10; border-color: #c88a10; }
      .bead.bead-active { background: #e8a020; border-color: #e8a020; box-shadow: 0 0 0 3px rgba(232,160,32,0.2); }

      /* Prayer screen */
      .prayer-context { font-size: 0.78rem; color: #aaa; font-style: italic; margin-bottom: 1.25rem; }
      .prayer-heading {
        font-size: 3rem; font-weight: 700; line-height: 1.1;
        letter-spacing: -0.02em; color: #111; margin: 0 0 0.4rem;
        overflow-wrap: break-word;
      }
      .prayer-count { font-family: monospace; font-size: 0.9rem; color: #e8a020; margin-bottom: 1.5rem; }
      .prayer-body {
        border-top: 1px solid #eee; padding-top: 1.25rem;
        font-size: 1.05rem; line-height: 1.85; color: #333;
        flex: 1;
      }

      /* Mystery announce */
      .mystery-ordinal {
        font-family: monospace; font-size: 0.72rem; color: #bbb;
        text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 0.4rem;
      }
      .mystery-heading {
        font-size: 2.6rem; font-weight: 700; line-height: 1.15;
        color: #111; margin: 0 0 1.25rem;
        overflow-wrap: break-word;
      }
      .mystery-desc { font-size: 1rem; line-height: 1.85; color: #666; flex: 1; }

      /* Closing */
      .closing-label {
        font-family: monospace; font-size: 0.72rem; color: #bbb;
        text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 1.5rem;
      }

      /* Nav — shared */
      .nav-row {
        display: flex; align-items: center; justify-content: space-between;
        padding-top: 1.5rem; margin-top: 2rem;
        border-top: 1px solid #f0f0f0;
      }
      .btn-nav { background: none; border: none; padding: 0; cursor: pointer; line-height: 1; }
      .btn-nav:disabled { opacity: 0.15; cursor: default; pointer-events: none; }

      /* Nav — minimal: plain arrow icons */
      .app:not(.classic) .btn-nav {
        font-size: 1.5rem; color: #ccc;
        transition: color 0.15s;
      }
      .app:not(.classic) .btn-nav:hover:not(:disabled) { color: #555; }
      .app:not(.classic) .btn-nav-next { color: #e8a020; }
      .app:not(.classic) .btn-nav-next:hover:not(:disabled) { color: #c88a10; }

      /* Nav — classic: icon buttons */
      .app.classic .btn-nav { transition: transform 0.15s; }
      .app.classic .btn-nav:hover:not(:disabled) { transform: scale(1.1); }
      .app.classic .btn-nav:active:not(:disabled) { transform: scale(0.9); }

      /* Completion */
      .completion {
        flex: 1; display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center; padding: 2rem 1.5rem;
      }
      .completion-icon { font-size: 3.5rem; color: #e8a020; margin-bottom: 1.5rem; line-height: 1; }
      .completion-symbol { font-size: 3rem; color: #e8a020; margin: 0 0 1.5rem; line-height: 1; }
      .completion-heading { font-size: 2rem; font-weight: 700; color: #111; margin: 0 0 0.5rem; }
      .completion-sub { font-size: 1rem; color: #888; margin-bottom: 2.5rem; }
      .btn-restart {
        background: #111; color: #fff; border: none;
        border-radius: 30px; padding: 0.75rem 2.5rem;
        font-family: 'Lora', serif; font-size: 1rem; cursor: pointer;
        transition: background 0.15s;
        display: inline-flex; align-items: center; gap: 0.5rem;
      }
      .btn-restart:hover { background: #333; }

      /* Minimal completion overrides */
      .app:not(.classic) .completion-heading { font-size: 2.8rem; letter-spacing: -0.02em; }
      .app:not(.classic) .btn-restart {
        background: none; border: none; border-bottom: 1px solid #ccc;
        border-radius: 0; padding: 0.2rem 0; color: #888;
        font-family: 'Lora', serif; font-size: 0.95rem; cursor: pointer;
        transition: color 0.15s, border-color 0.15s;
      }
      .app:not(.classic) .btn-restart:hover { color: #333; border-color: #888; }

      /* ── Announcement screen ── */
      /* Minimal: amber accent rule above ordinal + amber heading */
      .app:not(.classic) .mystery-ordinal {
        color: #e8a020; font-size: 0.78rem; letter-spacing: 0.2em;
        border-top: 2px solid #e8a020; padding-top: 1rem; margin-top: 0.25rem;
      }
      .app:not(.classic) .mystery-heading { color: #c88a10; }

      /* Classic: amber background wash + ordinal badge + desc card */
      .app.classic .content-announce { background: #fffdf7; }
      .app.classic .mystery-ordinal {
        display: inline-block;
        background: #fffbf0; border: 1px solid #e8a020; border-radius: 20px;
        padding: 0.2rem 0.85rem; font-size: 0.7rem; color: #c88a10;
        font-family: monospace; letter-spacing: 0.1em; text-transform: uppercase;
        margin-bottom: 0.75rem;
      }
      .app.classic .mystery-desc {
        flex: initial;
        background: #fff; border-radius: 8px;
        padding: 1.25rem 1.25rem 1.25rem 1.5rem;
        border-left: 4px solid #e8a020;
        box-shadow: 0 1px 5px rgba(0,0,0,0.08);
        color: #444; margin-bottom: 0.5rem;
      }

      /* ── Classic theme overrides ── */
      .app.classic { background: #f8f9fa; }

      .app.classic .app-header {
        box-shadow: 0 1px 4px rgba(0,0,0,0.07);
      }
      .app.classic .mystery-name { font-size: 1rem; }

      .app.classic .prayer-heading { font-size: 2.2rem; letter-spacing: normal; }
      .app.classic .mystery-heading { font-size: 2rem; letter-spacing: normal; }

      .app.classic .prayer-count {
        display: inline-block;
        background: #fffbf0; border: 1px solid #e8a020; border-radius: 20px;
        padding: 0.15rem 0.8rem; font-size: 0.78rem; color: #c88a10;
        margin-bottom: 1.5rem;
      }
      .app.classic .prayer-body {
        border-top: none; padding-top: 0; flex: initial;
        background: #fff; border-radius: 8px;
        padding: 1.25rem 1.25rem 1.25rem 1.5rem;
        border-left: 4px solid #e8a020;
        box-shadow: 0 1px 5px rgba(0,0,0,0.08);
        margin-bottom: 0.5rem;
      }
      .app.classic .decade-dot { width: 30px; height: 30px; }
      .app.classic .bead { width: 20px; height: 20px; }
      .app.classic .bead.bead-special { width: 25px; height: 25px; }

      @media (max-width: 600px) {
        .prayer-heading  { font-size: 2.3rem; }
        .mystery-heading { font-size: 2rem; }
        .content { padding: 1.25rem 1.25rem 1.75rem; }
        .app.classic .prayer-heading  { font-size: 1.9rem; }
        .app.classic .mystery-heading { font-size: 1.7rem; }
      }
    </style>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
